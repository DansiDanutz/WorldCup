{
  "name": "worldcup26-ad-video",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Render the WorldCup26 animated HTML ad to an MP4 with an ElevenLabs voiceover.",
  "scripts": {
    "serve": "python3 -m http.server 8099",
    "render": "FPS=30 DURATION=90 OUT=frames node render.mjs",
    "voice": "node gen_audio.mjs",
    "mux": "node mux.mjs",
    "overlay": "node render_overlay.mjs",
    "tiktok": "node render_overlay.mjs && node make_vertical.mjs"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.60.0"
  }
}
