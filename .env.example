NEXT_PUBLIC_SITE_URL=https://worldcup26.world
NEXT_PUBLIC_SUPABASE_URL=https://lxhjfdxowpxzrybxdasi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-games-project-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-for-server-routes-only
# Comma-separated Google account emails allowed to use the /admin console.
ADMIN_EMAILS=admin@example.com
# Owner admin Google account. Defaults to the built-in owner for continuity.
# Set to a different email to rotate ownership, or to "none" to remove the
# built-in owner entirely (break-glass ADMIN_RESULT_SECRET still works).
OWNER_ADMIN_EMAIL=
# Break-glass secret for admin routes when email auth is unavailable (sent in the x-admin-secret header).
ADMIN_RESULT_SECRET=replace-with-admin-secret
CRON_SECRET=replace-with-cron-secret
# Pre-launch ONLY: when set to 1, allowlisted ADMIN_EMAILS may exercise real
# paid actions (deposit/ticket/entry/withdrawal) before the public launch gate
# and geo checks open, for controlled launch testing. Leave empty in production
# and turn off before public launch.
PAID_ACTION_LAUNCH_TEST_BYPASS=
# Optional paid-action jurisdiction controls. Use ISO-3166 alpha-2 country
# codes from hosting headers such as x-vercel-ip-country. Leave both empty to
# allow all countries. If WORLDCUP_ALLOWED_COUNTRIES is set, only those
# countries can access paid entries/deposits. WORLDCUP_BLOCKED_COUNTRIES always
# blocks listed countries.
WORLDCUP_ALLOWED_COUNTRIES=
WORLDCUP_BLOCKED_COUNTRIES=
# Optional responsible deposit claim guardrails. Leave empty for no configured cap.
WORLDCUP_MAX_DEPOSIT_CLAIM_AMOUNT_USDT=
WORLDCUP_MAX_DAILY_DEPOSIT_CLAIM_AMOUNT_USDT=
# Optional responsible withdrawal request guardrails. Leave empty for no configured cap.
WORLDCUP_MAX_WITHDRAWAL_REQUEST_AMOUNT_USDT=
WORLDCUP_MAX_DAILY_WITHDRAWAL_REQUEST_AMOUNT_USDT=
# Contact channel shown to players for sending 18+ age-verification documents
# before a payout. Defaults to age-verification@worldcup26.world if unset.
WORLDCUP_AGE_VERIFICATION_CONTACT=
RESULT_API_URL=
RESULT_API_KEY=
# KuCoin Broker (ND) API — USDT deposits. Set on the server only; never commit real values.
KUCOIN_BROKER_API_BASE=https://api-broker.kucoin.com
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
KUCOIN_BROKER_NAME=
KUCOIN_BROKER_KEY=
# Optional shared main-account receive addresses. These are public receive
# addresses, not API secrets. Use only when deposits are matched manually.
KUCOIN_MAIN_USDT_TRC20_ADDRESS=
KUCOIN_MAIN_USDT_ERC20_ADDRESS=
# Optional read-only main-account API key used by production smoke checks to
# verify KuCoin USDT account/deposit-history access. Do not enable trading or withdrawals.
KUCOIN_MAIN_API_BASE=https://api.kucoin.com
KUCOIN_MAIN_API_KEY=
KUCOIN_MAIN_API_SECRET=
KUCOIN_MAIN_API_PASSPHRASE=
